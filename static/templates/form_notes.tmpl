<section>
  <article id="article" class="wide">

<!-- Popup overlay for user info -->
<div id="user-popup-overlay">
  <div id="user-popup">
    <div id="user-popup-content"></div>
    <div id="user-popup-header">
      <button id="user-popup-close" class="button button-small user-popup-close">Close</button>
    </div>
  </div>
</div>
<form action="{{.Base}}/notes"
      method="post"
      enctype="multipart/form-data"
      name="web_search"
      id="web_search"
      class="form">

    <b>DID:</b> {{.did}}
    <input class="input" type="hidden" name="did" value="{{.did}}">
    <br/>

    <label><b>Record description:</b></label>
    <input class="input" type="hidden" name="description" value="{{.description}}">
    {{.description}}
    <br/>

    <label><b>New note entry:</b></label>
    <textarea class="input"
              id="entry"
              name="entry"
              rows="5"></textarea>
    <br/>

    <!-- NEW: file upload -->
    <label><b>Attach image:</b></label>
    <input class="input"
           type="file"
           name="image"
           accept="image/*">
    <br/>
    <br/>

    <button class="button button-primary">Update</button>
</form>

<hr>

<div class="entry-list">
{{if eq (len .Entries) 0}}
    No previous entries found
{{else}}
    {{range .Entries}}
    <div class="entry-card">
        <div class="">
            <img src="https://cdn.onlinewebfonts.com/svg/img_467682.png" alt="Sync" style="width:20px;">
        </div>
        <div class="entry-content">
          <div class="entry-meta">
              <span class="ts">
                  {{.Date.Format "2006-01-02 15:04:05 UTC"}}
              </span>
              <span class="user">
                  <a href="/users?user={{.User}}" title="User" class="user-info-btn">
                  &#64;{{.User}}
                  </a>
              </span>
          </div>

          <div class="entry-body">
              {{.Text}}
          <!-- NEW: show image if exists -->
          {{if .ImageURL}}
              <br/>
              <img src="{{.ImageURL}}" style="max-width:300px;">
          {{end}}

          </div>

        </div>
    </div>
    {{end}}
{{end}}
</div>

  </article>
</section>
